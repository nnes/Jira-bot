# =============================================================================
# Environment Configuration for Teams-Jira Multi-Model AI Agent
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Base URL + API key của provider tương thích OpenAI SDK (custom base_url).
LLM_BASE_URL=https://your-llm-provider/v1
LLM_API_KEY=your-openai-compatible-api-key

# Multi-Model routing (xem CLAUDE.md §3)
ORCHESTRATOR_MODEL=minimax/minimax-m2.5      # Intent + slot-filling (chatbot, multi-turn conversation)
RERANKER_MODEL=qwen/qwen3-reranker-8b        # Context enricher (chỉ khi có Confluence link)
GENERATOR_MODEL=google/gemma-4-31b-it        # Fintech reasoning + Jira ticket generator (31B IT)
FALLBACK_MODEL=openai/gpt-oss-20b                   # Backup orchestrator khi minimax lỗi/timeout

# -----------------------------------------------------------------------------
# Jira Server Configuration (READ + CREATE only — KHÔNG delete)
# -----------------------------------------------------------------------------
# URL: http://your-jira-server:8080
JIRA_SERVER_URL=http://localhost:8080
JIRA_USER_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-pat-token

# -----------------------------------------------------------------------------
# Confluence Server Configuration (STRICTLY READ-ONLY)
# -----------------------------------------------------------------------------
# URL: http://your-confluence-server:8090
CONFLUENCE_SERVER_URL=http://localhost:8090
CONFLUENCE_USER_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-pat-token

# -----------------------------------------------------------------------------
# Microsoft Teams Bot / Bot Framework Emulator
# -----------------------------------------------------------------------------
# LOCAL/EMULATOR: để TRỐNG App ID & Password.
# Chỉ điền khi deploy lên Azure Bot Service / MS Teams thật.
# Emulator -> Open Bot -> http://localhost:8080/api/messages
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_PASSWORD=

# EMULATOR_MODE: set true khi test local với Bot Framework Emulator mà TEAMS_BOT_APP_ID đã được điền.
# Disables JWT auth check → Emulator không cần gửi token.
# TUYỆT ĐỐI KHÔNG set true trên production.
EMULATOR_MODE=false

# -----------------------------------------------------------------------------
# GreenNode AgentBase (Memory + Identity)
# -----------------------------------------------------------------------------
# MEMORY_ID: ID của memory store trên AgentBase (tạo qua /agentbase-memory).
# Khi set, LangGraph dùng AgentBaseMemoryEvents checkpointer để persist state.
# Để trống → fallback về in-memory ConversationStore (không bền qua restart).
MEMORY_ID=memory-0220ed70-c577-4674-ad59-6a1ff9244204

# AGENT_IDENTITY_NAME: tên identity trên AgentBase để retrieve API keys lúc runtime.
# Khi set, app tự lấy JIRA/Confluence/LLM key từ AgentBase thay vì đọc từ .env.
AGENT_IDENTITY_NAME=clawathon-agent

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
DEBUG=false

# -----------------------------------------------------------------------------
# Surface toggles — SECURE BY DEFAULT (all false = production-safe)
# -----------------------------------------------------------------------------
# Local dev / Bot Framework Emulator: set all three to true.
# Production (Azure Bot Service hosts the bot): leave all false.
#
# ENABLE_MESSAGES_ENDPOINT: expose the local POST /api/messages bot endpoint.
#   LOCAL=true   PRODUCTION=false (Azure Bot Service handles messaging)
# ENABLE_DIAGNOSTICS: expose /api/jira/check + /api/confluence/check
#   (info disclosure + SSRF surface — keep false in production)
# ENABLE_DOCS: expose Swagger /docs, /redoc, /openapi.json
ENABLE_MESSAGES_ENDPOINT=false
ENABLE_DIAGNOSTICS=false
ENABLE_DOCS=false

# -----------------------------------------------------------------------------
# Rate limiting (bot message handler)
# -----------------------------------------------------------------------------
# Under the limit → processed immediately. Over the limit → request is queued and
# the user is notified; rejected only if the queue wait exceeds the max below.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_QUEUE_WAIT_SECONDS=300
